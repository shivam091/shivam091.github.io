# ── MongoDB ───────────────────────────────────────────────────────────────────
# Create a free cluster at: https://cloud.mongodb.com
# Connection string from: Cluster → Connect → Drivers

MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/
MONGODB_DB=blog

# ── Google reCAPTCHA v3 ───────────────────────────────────────────────────────
# Register at: https://www.google.com/recaptcha/admin/create
# Choose reCAPTCHA v3, add your domain(s)

# Server-side secret key — NEVER expose to client
RECAPTCHA_SECRET_KEY=your-recaptcha-v3-secret-key

# Client-side site key — safe to expose (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-v3-site-key

# ── NextAuth (Auth.js v5) ─────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth App — https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your-github-app-client-id
GITHUB_SECRET=your-github-app-client-secret

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email address that gets admin dashboard access
ADMIN_EMAIL=your@email.com

# ── Rails API backend (optional) ─────────────────────────────────────────────
# Only set these if using the rails-api/ app instead of Next.js API routes
# Deploy rails-api/ to Railway: https://railway.app

NEXT_PUBLIC_RAILS_API_URL=https://your-app.up.railway.app
