<h1 class="text-2xl font-bold mb-6">Contact Submissions <span class="text-sm font-normal text-gray-500"><%= @submissions.count %> total</span></h1>

<div class="overflow-x-auto">
  <table class="w-full text-sm border-collapse">
    <thead>
      <tr class="border-b">
        <th class="text-left p-2 font-semibold">Name</th>
        <th class="text-left p-2 font-semibold">Email</th>
        <th class="text-left p-2 font-semibold">Message</th>
        <th class="text-left p-2 font-semibold">Date</th>
      </tr>
    </thead>
    <tbody>
      <% @submissions.each do |s| %>
        <tr class="border-b hover:bg-gray-50">
          <td class="p-2"><%= s.name %></td>
          <td class="p-2"><%= s.email %></td>
          <td class="p-2 max-w-xs truncate" title="<%= s.message %>"><%= s.message %></td>
          <td class="p-2 whitespace-nowrap"><%= s.createdAt&.strftime("%b %d, %Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @submissions.empty? %>
    <p class="text-center py-12 text-gray-400">No submissions yet.</p>
  <% end %>
</div>
